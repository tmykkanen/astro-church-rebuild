---
import '#/styles/global.css';

import { MainWrapper } from '#/components/wrappers';

import Base from './Base.astro';

interface Props {
	pageTitle: string;
	class?: string;
}

const { pageTitle, class: className } = Astro.props;
---

<Base {pageTitle}>
	<MainWrapper class={className}>
		<slot />
	</MainWrapper>
</Base>
