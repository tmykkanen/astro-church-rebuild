---
import '#/styles/global.css';

import { Font } from 'astro:assets';

import Footer from '#/components/Footer.astro';
import Header from '#/components/Header.astro';
import { getConfig } from '#/content/getters';

interface Props {
	pageTitle: string;
}

const { pageTitle } = Astro.props;

const config = await getConfig('site');

const siteName = config.churchName.name ?? 'Church Website';
const metaTitle = pageTitle ? `${pageTitle} | ${siteName}` : siteName;
---

<!doctype html>
<html lang="en">
	<head>
		<!-- bejamas:astro-fonts:start -->
		<Font cssVariable="--font-sans" />
		<!-- bejamas:astro-fonts:end -->

		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width">
		<link rel="icon" type="image/svg+xml" href="/favicon.svg">
		<link rel="icon" href="/favicon.ico">
		<meta name="generator" content={Astro.generator}>

		<!-- TITLE -->
		<title>{metaTitle}</title>
	</head>
	<body class="min-h-svh flex flex-col">
		<Header />
		<slot />
		<Footer />
	</body>
</html>

<style>
html,
body {
	margin: 0;
	width: 100%;
	height: 100%;
}
</style>
