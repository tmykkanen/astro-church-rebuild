---
import type { GetStaticPaths } from 'astro';

import { EntryCard } from '#/components/card';
import {
	Combobox,
	Datepicker,
	FiltersWrapper,
	Search,
} from '#/components/filters';
import { getBlog, getFeatureNavigationEntry } from '#/content/getters';
import { MainLayout } from '#/layouts';

export const getStaticPaths = (async () => {
	const blogNavigationEntry = await getFeatureNavigationEntry('blog');

	return blogNavigationEntry
		? [
				{
					params: {
						blog: blogNavigationEntry.customSlug || 'blog',
					},
					props: {
						blogNavigationEntry,
					},
				},
			]
		: [];
}) satisfies GetStaticPaths;

const { blogNavigationEntry } = Astro.props;

const allPosts = await getBlog();
---

<MainLayout pageTitle={blogNavigationEntry.label ?? 'Blog'}>
	<h1 class="sr-only">Blog</h1>
	<section class="flex flex-col gap-related-loose">
		<FiltersWrapper>
			<Fragment slot="label">All Posts</Fragment>
			<Search placeholder="Search posts..." slot="search" />
			<Combobox options={allPosts} />
			<Datepicker type="from" />
			<Datepicker type="to" />
		</FiltersWrapper>

		<div class="flex flex-col gap-related-loose xl:grid xl:grid-cols-2">
			{allPosts.map((post) => (<EntryCard entry={post} />))}
		</div>
	</section>
</MainLayout>

<script>
import { initAllFilters } from '#/components/filters';

initAllFilters();
</script>
