---
import { Image } from 'astro:assets';

import Text from '#/components/Text.astro';
import { Button } from '#/components/ui/button';
import { getConfig } from '#/content/getters';
import Layout from '#/layouts/Layout.astro';
import { generateClamp } from '#/lib/generateClamp';
import { getImage } from '#/lib/getImage';

const siteConfig = await getConfig('site');
const { hero, cta } = await getConfig('homepage');

const bgImg = getImage(hero?.bgImage);
---

<Layout pageTitle="Home">
	<main class="relative min-h-svh">
		<h1 class="sr-only">
			{siteConfig.churchName}
		</h1>
		<section
			class="grid min-h-svh w-full bg-cover bg-right"
			aria-labelledby="hero-heading"
		>
			{bgImg && (
			  <>
			    <Image
						src={bgImg}
						alt={'Homepage Background'}
						class="absolute inset-0 h-full w-full object-cover"
						priority
					/>
					<div
            class="bg-muted z-5 col-start-1 row-start-1 h-full w-full opacity-85"
            aria-hidden="true"
          />
			</>
		)}

			<div class="layout-base isolate z-20 col-start-1 row-start-1 gap-y-8">
				<Text
					as="h2"
					id="hero-heading"
					variant="hero"
					set:html={hero?.text.code}
				/>
				{cta?.text && (
            <Button
              as='a'
              variant={'secondary'}
              target={'_blank'}
              rel={'noopener noreferrer'}
              class={'uppercase tracking-widest whitespace-normal font-semibold h-auto w-full rounded-md text-center cursor-pointer'}
              style={`font-size:${generateClamp(0.75, 0.875)}`}
            >{cta.text.code}</Button>
          )}
			</div>
		</section>
	</main>
</Layout>
