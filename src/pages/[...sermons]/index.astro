---
import type { GetStaticPaths } from 'astro';

import Text from '#/components/Text.astro';
import { Button } from '#/components/ui/button';
import { getFeatureNavigationEntry } from '#/content/lib/getNavigation';
import Layout from '#/layouts/Layout.astro';
export const getStaticPaths = (async () => {
	const sermonNavigationEntry = await getFeatureNavigationEntry('sermons');

	return sermonNavigationEntry
		? [
				{
					params: {
						sermons:
							sermonNavigationEntry.customSlug ||
							sermonNavigationEntry.featureType,
					},
					props: {
						sermonNavigationEntry,
					},
				},
			]
		: [];
}) satisfies GetStaticPaths;

const { sermonNavigationEntry } = Astro.props;
---

<Layout
	pageTitle={sermonNavigationEntry.label ?? sermonNavigationEntry.featureType}
>
	<main class="layout-base gap-8 py-8">
		<h1 class="sr-only">Sermons</h1>
		<section class="flex min-w-0 flex-col gap-4">
			<Text as="h2" variant="heading">Latest Sermon</Text>
			<Button as="a">Lastest Sermon Title / Link</Button>
		</section>
	</main>
</Layout>
