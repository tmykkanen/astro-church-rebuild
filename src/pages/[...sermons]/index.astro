---
import type { GetStaticPaths } from 'astro';

import { EntryCard } from '#/components/card';
import { Embed } from '#/components/embed';
import {
	Combobox,
	Datepicker,
	FiltersWrapper,
	Search,
} from '#/components/filters';
import { Meta } from '#/components/meta';
import {
	getFeatureNavigationEntry,
	getPreachers,
	getSeries,
	getSermons,
} from '#/content/getters';
import { MainLayout } from '#/layouts';

export const getStaticPaths = (async () => {
	const sermonNavigationEntry = await getFeatureNavigationEntry('sermons');

	return sermonNavigationEntry
		? [
				{
					params: {
						sermons: sermonNavigationEntry.customSlug || 'sermons',
					},
					props: {
						sermonNavigationEntry,
					},
				},
			]
		: [];
}) satisfies GetStaticPaths;

const { sermonNavigationEntry } = Astro.props;

const allSermons = await getSermons();
const allSeries = await getSeries();
const allPreachers = await getPreachers();
const latestSermon = allSermons[0];

if (!latestSermon) return;

const baseUrl = sermonNavigationEntry.customSlug || 'sermons';
---

<MainLayout pageTitle={sermonNavigationEntry.label ?? 'Sermons'}>
	<h1 class="sr-only">Sermons</h1>

	<!-- Display Latest Sermon -->
	<section class="flex min-w-0 flex-col gap-related-tight">
		<h2 class="typo-h2">Latest Sermon</h2>
		<a
			class="typo-h3 hover:underline hover:decoration-primary underline-offset-4 w-fit"
			href={`${baseUrl}/${latestSermon.id}`}
			>{latestSermon.data.title}</a
		>
		<Meta entry={latestSermon} />
		<div class="h-38">
			<Embed entry={latestSermon} isCompact />
		</div>
	</section>

	<section class="flex flex-col gap-related-loose">
		<FiltersWrapper>
			<Fragment slot="label">All Sermons</Fragment>
			<Search placeholder="Search sermons..." slot="search" />
			<Combobox options={allSeries} />
			<Combobox options={allPreachers} />
			<Datepicker type="from" />
			<Datepicker type="to" />
		</FiltersWrapper>

		<div class="flex flex-col gap-related-loose xl:grid xl:grid-cols-2">
			{allSermons.map((sermon) => (<EntryCard entry={sermon} />))}
		</div>
	</section>
</MainLayout>

<script>
import { initAllFilters } from '#/components/filters';

initAllFilters();
</script>
