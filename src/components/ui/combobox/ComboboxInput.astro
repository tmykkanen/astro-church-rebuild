---
import type { HTMLAttributes } from "astro/types";
import { cn } from "#/lib/utils";
import {
  InputGroup,
  InputGroupInput,
  InputGroupAddon,
  InputGroupButton,
} from "../input-group";

interface Props extends Omit<HTMLAttributes<"input">, "size"> {
  class?: string;
  size?: "sm" | "default" | "lg";
  placeholder?: string;
  disabled?: boolean;
  showTrigger?: boolean;
  showClear?: boolean;
}

const {
  class: className = "",
  size = "default",
  placeholder,
  disabled = false,
  showTrigger = true,
  showClear = false,
  ...rest
} = Astro.props as Props;
---

<InputGroup size={size} class={cn("w-auto", className)}>
  <InputGroupInput
    data-input-group-control
    data-slot="combobox-input"
    placeholder={placeholder}
    disabled={disabled}
    autocomplete="off"
    {...rest}
   class="" />
  {
    (showTrigger || showClear) && (
      <InputGroupAddon align="inline-end">
        {showClear && (
          <InputGroupButton
            data-slot="combobox-clear"
            type="button"
            size="icon-xs"
            class="hidden [[data-value]_&]:inline-flex"
            aria-label="Clear selection"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-3.5 group-data-[size=sm]/input-group:size-3"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 6L6 18M6 6l12 12"/></svg>
          </InputGroupButton>
        )}
        {showTrigger && (
          <InputGroupButton
            data-slot="combobox-trigger"
            type="button"
            size="icon-xs"
            tabindex={-1}
            disabled={disabled}
            class={cn("[&_svg:not([class*='size-'])]:size-4 rounded-lg", 
              "text-muted-foreground",
              showClear && "[[data-value]_&]:hidden",
            )}
            aria-label="Toggle menu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" data-slot="combobox-icon"
              class="size-4 group-data-[size=sm]/input-group:size-3.5"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9l6 6l6-6"/></svg>
          </InputGroupButton>
        )}
      </InputGroupAddon>
    )
  }
</InputGroup>
