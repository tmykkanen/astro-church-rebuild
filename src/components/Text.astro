---
import type { HTMLTag, Polymorphic } from 'astro/types';

// clamp(min, (vw coefficient)vw + (intercept)px, max)
// To calculate (vw coefficient)vw + (intercept)px
// Slope = (maxFontPx - minFontpx) / (maxVw - minVw) | (208-96) / (1440-375)
// vw coefficient = slope x 100 | 0.10516 x 100
// intercept = minSize - slope × minViewport | 375 - (0.10516 x 375)
const variants = {
	default: '',
	displayLG:
		'text-[clamp(1.25rem,2.54vw+10.475px,1.875rem)] uppercase font-bold',
	hero: 'font-sans text-[clamp(6rem,2.54vw+10.475px,13rem)] leading-[0.85] text-background text-center',
	subheading: 'text-[clamp(24px,3.82vw+9px,64px)] font-bold',
	subSubheading: 'text-[clamp(20px,2.6vw+10px,40px)] font-bold',
	footerHeading: 'text-2xl font-bold font-sans',
	footerBase: 'text-base',
};

type Variant = keyof typeof variants;

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	variant?: Variant;
	class?: string;
}>;

const {
	as: As = 'p',
	variant = 'default',
	class: className,
	...attrs
} = Astro.props as Props<HTMLTag>;
---

<As class:list={[variants[variant], className]} {...attrs}>
	<slot />
</As>
