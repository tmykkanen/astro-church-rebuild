---
import type { HTMLTag, Polymorphic } from 'astro/types';

import { generateClamp } from '#/lib/generateClamp';

const variants = {
	default: {
		class: '',
		style: {},
	},
	navTop: {
		class:
			'hover:underline hover:decoration-primary underline-offset-4 text-xl font-bold text-primary uppercase',
		style: {
			'font-size': generateClamp(1.875, 3, { maxViewportWidth: 1024 }),
		},
	},
	navChild: {
		class:
			'hover:underline hover:decoration-primary underline-offset-4 text-muted-foreground font-bold uppercase text-xl',
		style: {
			'font-size': generateClamp(1, 1.25, { maxViewportWidth: 1024 }),
		},
	},
	link: {
		class: 'hover:decoration-primary hover:text-foreground underline',
		style: {},
	},
	heading: {
		class: 'uppercase tracking-wider',
		style: {
			'font-size': generateClamp(1.25, 1.5),
		},
	},
	subheading: {
		class: '',
		style: {
			'font-size': generateClamp(1.125, 1.25),
		},
	},
	sermonHeading: {
		class: 'uppercase font-bold',
		style: {
			'font-size': generateClamp(1.875, 3),
		},
	},
	displayLG: {
		class: 'uppercase font-bold',
		style: {
			'font-size': generateClamp(1.25, 1.875),
		},
	},
	displayXL: {
		class: 'font-bold uppercase leading-none',
		style: {
			'font-size': generateClamp(3, 4.5),
		},
	},
};

export type Variant = keyof typeof variants;

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	variant?: Variant;
	class?: string;
}>;

const {
	as: As = 'p',
	variant = 'default',
	class: className,
	...attrs
} = Astro.props as Props<HTMLTag>;

const selectedVariant = variants[variant];
---

<As
	class:list={[selectedVariant.class, className]}
	style={selectedVariant.style}
	{...attrs}
>
	<slot />
</As>
