---
import type { HTMLTag, Polymorphic } from 'astro/types';

import { generateClamp } from '#/lib/generateClamp';

const variants = {
	default: {
		class: '',
		style: {},
	},
	link: {
		class: 'hover:decoration-primary hover:text-foreground underline',
		style: {},
	},
	hero: {
		class: 'uppercase font-bold tracking-[0.1rem]',
		style: {
			'font-size': generateClamp(3.05, 4.77),
			'line-height': 1,
		},
	},
	'heading-1': {
		class: 'uppercase font-medium tracking-[0.07rem]',
		style: {
			'font-size': generateClamp(1.56, 2.44),
			'line-height': 1.1,
		},
	},
	'heading-2': {
		class: 'uppercase font-medium tracking-[0.05rem]',
		style: {
			'font-size': generateClamp(1.25, 1.95),
			'line-height': 1.2,
		},
	},
	'heading-3': {
		class: 'uppercase tracking-[0.05rem]',
		style: {
			'font-size': generateClamp(1, 1.56),
			'line-height': 1.3,
		},
	},
	'heading-4': {
		class: 'tracking-[0.01rem]',
		style: {
			'font-size': generateClamp(0.8, 1.25),
			'line-height': 1.3,
		},
	},
	body: {
		class: '',
		style: {
			'font-size': generateClamp(0.8, 1),
			'line-height': 1.6,
		},
	},
};

export type Variant = keyof typeof variants;

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	variant?: Variant;
	class?: string;
}>;

const {
	as: As = 'p',
	variant = 'default',
	class: className,
	...attrs
} = Astro.props as Props<HTMLTag>;

const selectedVariant = variants[variant];
---

<As
	class:list={[selectedVariant.class, className]}
	style={selectedVariant.style}
	{...attrs}
>
	<slot />
</As>
