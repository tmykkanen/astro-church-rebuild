---
import type { HTMLTag, Polymorphic } from 'astro/types';

import { generateClamp } from '#/lib/generateClamp';

// const variants = {
// 	hero: 'font-sans text-[clamp(6rem,2.54vw+10 .475px,13rem)] leading-[0.85] text-background text-center',
// 	subheading: 'text-[clamp(24px,3.82vw+9px,64px)] font-bold',
// 	subSubheading: 'text-[clamp(20px,2.6vw+10px,40px)] font-bold',
// 	footerHeading: 'text-2xl font-bold font-sans',
// 	footerBase: 'text-base',
// };

const variants = {
	default: {
		class: '',
		style: {},
	},
	heading: {
		class: 'uppercase tracking-wider',
		style: {
			'font-size': generateClamp(1.25, 1.5),
		},
	},
	displayLG: {
		class: 'uppercase font-bold',
		style: {
			'font-size': generateClamp(1.25, 1.875),
		},
	},
	displayXL: {
		class: 'font-bold uppercase leading-none',
		style: {
			'font-size': generateClamp(3, 4.5),
		},
	},
};

type Variant = keyof typeof variants;

type Props<Tag extends HTMLTag> = Polymorphic<{
	as: Tag;
	variant?: Variant;
	class?: string;
}>;

const {
	as: As = 'p',
	variant = 'default',
	class: className,
	...attrs
} = Astro.props as Props<HTMLTag>;

const selectedVariant = variants[variant];
---

<As
	class:list={[selectedVariant.class, className]}
	style={selectedVariant.style}
	{...attrs}
>
	<slot />
</As>
