---
import { Image } from 'astro:assets';

import DesktopNav from '#/components/nav/DesktopNav.astro';
import MobileNav from '#/components/nav/MobileNav.astro';
import Text from '#/components/Text.astro';
import { siteConfig } from '#/config/index';
import { getNavigation } from '#/content/navigation/getNavigation';

const assetsImages = import.meta.glob<{ default: ImageMetadata }>(
	'src/assets/*',
);
const currentPath = Astro.url.pathname;

const primaryNav = await getNavigation('primary');
---

<header
	class:list={["layout-full py-4 h-26 flex w-full items-center justify-end md:justify-center", currentPath !== "/" && "bg-muted"]}
>
	<div class="flex w-full items-center">
		{siteConfig?.header?.displayTitle
			? ( <Text as="h2" variant="displayLG" class='flex-1'
				><a href="/">{siteConfig.general.name}</a></Text
			>
			) :
			(<h2 class="sr-only">{siteConfig.general.name}</h2>)}

		{siteConfig?.header?.displayLogo && siteConfig.general.logo && (
		<Image
          src={assetsImages[`/${siteConfig.general.logo}`]()}
          alt="logo"
          class={"max-h-18"}
        />
		)}
	</div>
	<DesktopNav navigationEntries={primaryNav} />
	<MobileNav navigationEntries={primaryNav} />
</header>
