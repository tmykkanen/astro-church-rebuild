---
import { Image } from 'astro:assets';

import DesktopNav from '#/components/nav/DesktopNav.astro';
import MobileNav from '#/components/nav/MobileNav.astro';
import Text from '#/components/Text.astro';
import { getConfig } from '#/content/config/getConfig';
import { getNavigation } from '#/content/navigation/getNavigation';
import { getImage } from '#/lib/getImage';

const config = await getConfig('site');

const logo = getImage(config.churchLogo?.image);

const currentPath = Astro.url.pathname;

const primaryNav = await getNavigation('primary');
---

<header
	class:list={["layout-full py-4 h-26", currentPath !== "/" && "bg-muted"]}
>
	<div class="flex justify-center md:justify-end">
		<div class="flex w-full items-center gap-4">
			{config.churchName.showInHeader
			? ( <Text as="h2" variant="displayLG"
				><a href="/">{config.churchName.name}</a></Text
			>
			) :
			(<h2 class="sr-only">{config.churchName.name}</h2>)}

			{logo && config.churchLogo?.showInHeader &&  (
		<Image
          src={logo}
          alt="logo"
          class={"max-h-18"}
        />
		)}
		</div>
		<DesktopNav navigationEntries={primaryNav} />
		<MobileNav navigationEntries={primaryNav} />
	</div>
</header>
