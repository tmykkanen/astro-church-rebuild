---
import type { Variant } from '#/components/Text.astro';
import Text from '#/components/Text.astro';
import type {
	NavigationExternalEntry,
	NavigationFeatureEntry,
	NavigationPageEntry,
} from '#/content/types/navigation';

interface Props {
	class?: string;
	entry: NavigationPageEntry | NavigationExternalEntry | NavigationFeatureEntry;
	variant?: Variant;
}

const { class: className = '', entry, variant = 'heading-1' } = Astro.props;

let href: string;

switch (entry.navigationEntryType) {
	case 'external':
		href = entry.url;
		break;
	case 'feature':
		href = `/${entry.customSlug || entry.featureType}`;
		break;
	default:
		href = `/${entry.page.id}`;
}
---

<li>
	<Text as="a" {href} class={className} {variant}>{entry.label}</Text>
</li>
