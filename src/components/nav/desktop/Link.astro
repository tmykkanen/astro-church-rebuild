---
import type { HTMLAttributes } from 'astro/types';

import { NavigationMenuLink } from '#/components/ui/navigation-menu';
import type {
	NavigationExternalEntry,
	NavigationFeatureEntry,
	NavigationPageEntry,
} from '#/content/types/navigation';
import { cn } from '#/lib/utils';

interface Props extends HTMLAttributes<'a'> {
	class?: string;
	entry: NavigationPageEntry | NavigationExternalEntry | NavigationFeatureEntry;
}

const { class: className = '', entry, ...rest } = Astro.props;

let href: string;

switch (entry.navigationEntryType) {
	case 'external':
		href = entry.url;
		break;
	case 'feature':
		href = `/${entry.customSlug || entry.featureType}`;
		break;
	default:
		href = `/${entry.page.id}`;
}
---

<NavigationMenuLink
	href={`${href}`}
	class={cn(className, "hover:bg-secondary focus:bg-secondary data-open:hover:bg-secondary data-open:focus:bg-secondary data-open:bg-secondary/50")}
	{...rest}
>
	{entry.label}
</NavigationMenuLink>}
