---
import type { HTMLTag } from 'astro/types';

import { Badge } from '#/components/ui/badge';

interface Props {
	as?: HTMLTag;
}

const { as = 'span', ...props } = Astro.props as Props;
---

<Badge
	{as}
	shape="pill"
	class:list={'bg-muted text-muted-foreground text-xs [a]:hover:text-primary-foreground [a]:hover:bg-primary'}
	{...props}
>
	<slot />
</Badge>
